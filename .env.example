# ==============================
# VENDAS AUTO - CONFIGURAÇÃO
# ==============================
# Copie este arquivo para .env e preencha com suas credenciais reais

# ==============================
# SERVIDOR
# ==============================
NODE_ENV=development
PORT=3000
DEBUG_PASSWORD=sua_senha_segura_aqui

# ==============================
# WHATSAPP - META BUSINESS API
# ==============================

# Token de verificação do webhook (você cria um qualquer)
WHATSAPP_VERIFY_TOKEN=seu_token_aleatorio_aqui

# ID do número do WhatsApp Business (obtém do Meta)
# Formato: 120XXXXX (sem caracteres especiais)
WHATSAPP_PHONE_NUMBER_ID=120XXXXX

# Token de acesso da API Meta WhatsApp
# Formato: EAAxxxxx... (muito longo)
# Obtém em: https://developers.facebook.com/docs/whatsapp/cloud-api/
WHATSAPP_ACCESS_TOKEN=EAAxxx...

# ==============================
# GOOGLE GEMINI - IA
# ==============================

# API Key do Google Gemini
# Obtém em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaXXX...

# Modelo Gemini a usar (opcional)
# Padrão: gemini-pro
# Opções: gemini-pro, gemini-1.5-pro, etc
GEMINI_MODEL=gemini-pro

# ==============================
# DATABASE - PostgreSQL
# ==============================

# Host do PostgreSQL
DB_HOST=localhost

# Porta do PostgreSQL (padrão: 5432)
DB_PORT=5432

# Nome do banco de dados
DB_NAME=vendas_auto

# Usuário do PostgreSQL
DB_USER=postgres

# Senha do PostgreSQL
DB_PASSWORD=sua_senha_postgres

# ==============================
# LOGGING E DEBUG
# ==============================

# Nível de log: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=debug

# ==============================
# CONFIGURAÇÕES DE NEGÓCIO
# ==============================

# Preço do serviço de tráfego pago (em reais)
SERVICE_PRICE_TRAFFIC=1500

# Descrição do serviço principal
SERVICE_NAME_TRAFFIC=Tráfego Pago para Clínicas de Estética

# ==============================
# ENDPOINTS (para testes externos)
# ==============================

# URL base do seu servidor (para callbacks, etc)
APP_URL=http://localhost:3000

# ==============================
# SEGURANÇA
# ==============================

# CORS - Origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==============================
# FEATURES (ativar/desativar recursos)
# ==============================

# Ativar resposta automática de mensagens
AUTO_RESPONSE_ENABLED=true

# Ativar detecção de leads quentes
HOT_LEAD_DETECTION=true

# Timeout para chamadas à IA (em millisegundos)
AI_TIMEOUT=30000
