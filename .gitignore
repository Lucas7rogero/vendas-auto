training-data/
model-weights/

# ==============================
# BANCO DE DADOS
# ==============================

# Arquivos de banco local
*.db
*.sqlite
*.sqlite3

# PostgreSQL dumps
*.sql
database-backup/
db-backup/

# MongoDB (se usado)
*.mongodump

# ==============================
# DEPLOYMENT
# ==============================

# Docker
.dockerignore

# Heroku
Procfile

# AWS
.aws/
serverless.yml

# Vercel
.vercel/

