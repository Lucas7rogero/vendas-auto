# SEGURANÇA
# ==============================

# Chaves privadas
*.key
*.pem
*.crt
*.cer

# Tokens e secrets
secrets/
tokens/
credentials/

# Arquivos de senha
passwords.txt
secrets.txt

# ==============================
# OUTROS
# ==============================

# Arquivos grandes
*.zip
*.tar.gz
*.7z
*.rar

# Arquivos de vídeo/audio
*.mp4
*.avi
*.mp3
*.wav

# Imagens grandes (exceto assets)
large-images/
big-photos/

# Arquivos temporários do sistema
*.tmp
*.temp
*.swp
*.swo

# ==============================
# IMPORTANTE
# ==============================
# Este .gitignore protege dados sensíveis
# como .env, credenciais e arquivos temporários
#
# Para adicionar arquivos específicos:
# echo "arquivo.txt" >> .gitignore
#
# Para verificar o que será ignorado:
# git status --ignored
#
# Para remover arquivos já commitados:
# git rm --cached arquivo-sensivel.txt
# git commit -m "Remove arquivo sensível"
